# Ai Маркетолог — переменные окружения
# Скопируй этот файл в .env и заполни значения

BOT_TOKEN=your_telegram_bot_token_here

AI_PROVIDER=openrouter

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-r1

YANDEXGPT_API_KEY=your_yandexgpt_api_key_here
YANDEXGPT_FOLDER_ID=your_yandex_folder_id_here

MAX_INPUT_LENGTH=2000

COMPETITOR_MAX_LENGTH=3000

# Путь к файлу SQLite внутри контейнера
SQLITE_PATH=cardgen/data/bot.db

# TTL FSM-состояний в секундах (по умолчанию 86400 = 24 часа)
FSM_STATE_TTL=86400

# Таймаут HTTP-фетча карточки конкурента в секундах
COMPETITOR_FETCH_TIMEOUT=5

# Rate limiting: максимум запросов на пользователя за окно
RATE_LIMIT_MAX=3

# Rate limiting: окно в секундах
RATE_LIMIT_WINDOW=60

# Опционально (значения по умолчанию указаны):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# YANDEXGPT_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
# MAX_RETRIES=1
# DEFAULT_MAX_TOKENS=4096
# REQUEST_TIMEOUT=60
